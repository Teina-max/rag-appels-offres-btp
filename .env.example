# Copy these into ~/.secrets/rag-ao-btp.env (chmod 600) — loaded by ingest/src/env.ts.
# Never commit real secrets.

# Supabase (EU-region project) — session pooler URL, prepare:false in serverless
SUPABASE_DB_URL=postgres://user:password@host:6543/postgres

# Voyage AI embeddings
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3-large

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
